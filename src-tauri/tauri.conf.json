{
  "$schema": "https://raw.githubusercontent.com/nicedoc/raw/refs/heads/master/nicedoc/tauri-apps/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Cyberdeck",
  "version": "0.1.0",
  "identifier": "com.cyberdeck.app",
  "build": {
    "beforeDevCommand": "npm run dev -w @cyberdeck/web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build -w @cyberdeck/web",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cyberdeck",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
